@article{Peters2023,
  author    = {Peters, L. J. B. and Chattopadhyay, G. and Tuck, M. A.},
  title     = {Studies on the Impact of Road Freight Transport and Alternative Modes in Australia: A Literature Study},
  journal   = {International Journal of System Assurance Engineering and Management},
  year      = {2023},
  volume    = {14},
  number    = {4},
  pages     = {954--960},
  doi       = {10.1007/s13198-022-01693-3},
  url       = {https://doi.org/10.1007/s13198-022-01693-3},
  issn      = {0976-4348},
  abstract  = {The freight sector in Australia has been growing at an ever-increasing rate due to domestic and international demand for goods, commodities, and resources. Increased traffic leads to higher greenhouse gas emissions impacting climate change and air pollution. The European Union used Marco Polo to shift freight from road to sea, rail, and inland waterways to reduce congestion and pollution. Australia introduced Fuel Tax Credit to address similar issues. This study performs a systematic literature review using the Mixed Method Appraisal Tool and Critical Appraisal Skills Programme. Findings show that alternative transport modes for long distances reduce carbon dioxide emissions and increase the likelihood of renewable fuels such as electric and hydrogen trucks, though research on renewable fuels remains limited.}
}

